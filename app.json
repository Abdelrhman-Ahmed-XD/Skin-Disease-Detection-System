{
  "expo": {
    "name": "SkinSight",
    "slug": "SkinSight",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "assets/images/logo.png",
    "scheme": [
      "skinsight",
      "fb1602991657655981"
    ],
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "skipValidateProjectName": true,
    "ios": {
      "supportsTablet": true,
      "plugins": [
        "expo-router"
      ],
      "infoPlist": {
        "SKAdNetworkItems": [
          {
            "SKAdNetworkIdentifier": "v9wttpbfk9.skadnetwork"
          },
          {
            "SKAdNetworkIdentifier": "n38lu8286q.skadnetwork"
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "assets/images/logo1025.png",
        "monochromeImage": "assets/images/logo1025.png",
        "backgroundColor": "#D8E9F0"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.samuelmilad.skindisease",
      "permissions": [
        "android.permission.INTERNET"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo1025.png",
          "backgroundColor": "#000000",
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logo.png",
          "color": "#004F7F",
          "defaultChannel": "default"
        }
      ],
      [
        "react-native-fbsdk-next",
        {
          "appID": "1602991657655981",
          "clientToken": "af57bd0099d9289acc3e436ee258472a",
          "displayName": "SkinSight",
          "advertiserIDCollectionEnabled": false,
          "autoLogAppEventsEnabled": false,
          "isAutoInitEnabled": true
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "12833f91-7da8-4692-a2a8-25d812643e9e"
      }
    },
    "owner": "abdelrhman-ahmed"
  }
}